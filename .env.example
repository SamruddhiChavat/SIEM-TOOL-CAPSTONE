# RealSIEM Environment Configuration
# Copy this file to .env and adjust values for your environment.

# -------------------------------------
# Elasticsearch & Kibana Security
# -------------------------------------
ELASTIC_PASSWORD=changeme123!
KIBANA_PASSWORD=changeme123!

# -------------------------------------
# PostgreSQL (Alerts & Incidents DB) 
# -------------------------------------
POSTGRES_USER=siemuser
POSTGRES_PASSWORD=siempass123!
POSTGRES_DB=siemdb

# -------------------------------------
# Redis (State & Queuing)
# -------------------------------------
REDIS_PASSWORD=redispass123!

# -------------------------------------
# FastAPI Backend
# -------------------------------------
JWT_SECRET=super_secret_jwt_key_realsiem_2026
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# -------------------------------------
# Network Config
# -------------------------------------
LOCAL_SUBNET=192.168.1.0/24

# -------------------------------------
# Optional Threat Intel Config
# -------------------------------------
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# -------------------------------------
# Notifications (Optional)
# -------------------------------------
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=
ALERT_EMAIL_DEST=soc@example.com
SLACK_WEBHOOK_URL=
